# EnglishLegalese production environment template — do not commit real secrets.
NODE_ENV=production
APP_ENV=production
APP_BASE_URL=https://englishlegalese.com
PORT=10000

# Persistence and safe deployments
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME
PGSSLMODE=require
SESSION_SECRET=replace-with-long-random-secret
JWT_SECRET=replace-with-long-random-secret
BACKUP_PROVIDER=managed-postgres-plus-manual-exports
BACKUP_LAST_VERIFIED_AT=YYYY-MM-DDTHH:MM:SSZ

# Owner bootstrap; use once, then rotate/clear password var.
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-strong-temporary-password
OWNER_NAME=EnglishLegalese Owner

# Stripe
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_DIAGNOSTIC=price_...
STRIPE_PRICE_ASSESSMENT=price_...
STRIPE_PRICE_STARTER_5=price_...
STRIPE_PRICE_PRO_10=price_...
STRIPE_PRICE_AI_MEMBERSHIP=price_...

# Object storage: AWS S3, Cloudflare R2, or other S3-compatible provider.
S3_BUCKET=englishlegalese-production
S3_REGION=auto-or-region
S3_ENDPOINT=
S3_ACCESS_KEY_ID=replace
S3_SECRET_ACCESS_KEY=replace
S3_PUBLIC_BASE_URL=

# Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace
SMTP_PASS=replace
FROM_EMAIL=EnglishLegalese <no-reply@englishlegalese.com>

# Calendar and video
GOOGLE_CALENDAR_ID=primary-or-service-calendar-id
GOOGLE_CALENDAR_ACCESS_TOKEN=replace
GOOGLE_OAUTH_CLIENT_ID=replace
GOOGLE_OAUTH_CLIENT_SECRET=replace
ZOOM_ACCOUNT_ID=replace
ZOOM_CLIENT_ID=replace
ZOOM_CLIENT_SECRET=replace
ZOOM_WEBHOOK_SECRET_TOKEN=replace

# AI
# SmartTeacher AI is ChatGPT/OpenAI-only in v1.32. Do not add Gemini, Claude, Grok, Anthropic, xAI, or other AI vendor keys.
OPENAI_API_KEY=replace_with_openai_api_key
SMARTTEACHER_MODEL=gpt-4.1-mini

# Smoke tests
POST_DEPLOY_SMOKE_TEST_URL=https://englishlegalese.com/health
RENDER_SERVICE_ID=
RENDER_DATABASE_ID=

# v1.34 Calendar interop: no required extra secret for ICS/manual calendar fallback.
# Optional future calendar connectors may use MICROSOFT_GRAPH_* or CALDAV_* credentials. Google Calendar remains optional only.

# v1.54 public launch readiness controls — keep invite-only until gates pass.
PUBLIC_BETA_MODE=true
MANUAL_CLASSROOM_LINK_FALLBACK=true
LAUNCH_REQUIRE_STRIPE_FOR_PAID=true
LAUNCH_REQUIRE_POSTGRES_FOR_REAL_USERS=true
LAUNCH_REQUIRE_OBJECT_STORAGE_FOR_UPLOADS=true
LAUNCH_REQUIRE_SMARTTEACHER_KEY_FOR_AI=true
LAUNCH_REQUIRE_SMTP_FOR_EMAIL=true
LAUNCH_REQUIRE_BACKUP_RESTORE_TEST=true
