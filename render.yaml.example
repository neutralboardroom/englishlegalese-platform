# Example Render blueprint. Review before use. Do not put real secrets in this file.
services:
  - type: web
    name: englishlegalese-platform
    env: node
    plan: starter
    buildCommand: npm install && npm run predeploy:check
    startCommand: npm start
    healthCheckPath: /health
    envVars:
      - key: NODE_ENV
        value: production
      - key: APP_ENV
        value: production
      - key: APP_BASE_URL
        value: https://englishlegalese.com
      - key: DATABASE_URL
        fromDatabase:
          name: englishlegalese-db
          property: connectionString
      - key: SESSION_SECRET
        sync: false
      - key: STRIPE_SECRET_KEY
        sync: false
      - key: STRIPE_WEBHOOK_SECRET
        sync: false
      - key: OPENAI_API_KEY
        sync: false

databases:
  - name: englishlegalese-db
    plan: starter
    databaseName: englishlegalese
    user: englishlegalese
