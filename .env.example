# EnglishLegalese production configuration
NODE_ENV=development
PORT=3000

# Required for production persistence
DATABASE_URL=postgres://user:password@host:5432/englishlegalese
PGSSLMODE=require

# Development fallback only. Do not use for production data.
LOCAL_DATA_DIR=./data
LOCAL_JSON_DB=./data/local-dev-persistent-store.json

# Future production integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
OBJECT_STORAGE_PROVIDER=s3_or_r2_or_gcs
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
OBJECT_STORAGE_ACCESS_KEY_ID=
OBJECT_STORAGE_SECRET_ACCESS_KEY=
OPENAI_API_KEY=

# v1.19 production backend/security/integration settings
NODE_ENV=production
SESSION_SECRET=replace-with-long-random-secret
SESSION_TTL_SECONDS=604800
JSON_BODY_LIMIT=1mb

# Stripe payments and verified webhooks
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_SUCCESS_URL=https://englishlegalese.com/success
STRIPE_CANCEL_URL=https://englishlegalese.com/cancel
STRIPE_CURRENCY=usd

# S3-compatible secure object storage for uploads and PDF reports
S3_BUCKET=englishlegalese-production
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
# S3_ENDPOINT=https://<r2-or-s3-compatible-endpoint>
S3_FORCE_PATH_STYLE=false
S3_PRESIGN_TTL_SECONDS=900

# Email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=replace_me
SMTP_PASS=replace_me
MAIL_FROM=EnglishLegalese <noreply@englishlegalese.com>

# Google Calendar + Google Meet creation
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ACCESS_TOKEN=replace-with-oauth-access-token

# Zoom Server-to-Server OAuth meetings
ZOOM_ACCOUNT_ID=replace_me
ZOOM_CLIENT_ID=replace_me
ZOOM_CLIENT_SECRET=replace_me
ZOOM_USER_ID=me

# Server-side SmartTeacher AI
# SmartTeacher AI is ChatGPT/OpenAI-only in v1.32. Do not add Gemini, Claude, Grok, Anthropic, xAI, or other AI vendor keys.
OPENAI_API_KEY=replace_me
SMARTTEACHER_MODEL=gpt-5.5-mini


# v1.21 production activation controls
APP_ENV=development
APP_BASE_URL=https://englishlegalese.com
OWNER_EMAIL=owner@example.com
OWNER_PASSWORD=replace-with-strong-password
OWNER_NAME=EnglishLegalese Owner
BACKUP_PROVIDER=manual-or-managed-postgres
BACKUP_LAST_VERIFIED_AT=
RENDER_SERVICE_ID=
RENDER_DATABASE_ID=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=
POST_DEPLOY_SMOKE_TEST_URL=https://englishlegalese.com/health

# v1.34 Calendar interop: no required extra secret for ICS/manual calendar fallback.
# Optional future calendar connectors may use MICROSOFT_GRAPH_* or CALDAV_* credentials. Google Calendar remains optional only.

# v1.54 public launch readiness controls — placeholders only, do not commit real secrets.
PUBLIC_BETA_MODE=true
MANUAL_CLASSROOM_LINK_FALLBACK=true
LAUNCH_REQUIRE_STRIPE_FOR_PAID=true
LAUNCH_REQUIRE_POSTGRES_FOR_REAL_USERS=true
LAUNCH_REQUIRE_OBJECT_STORAGE_FOR_UPLOADS=true
LAUNCH_REQUIRE_SMARTTEACHER_KEY_FOR_AI=true
LAUNCH_REQUIRE_SMTP_FOR_EMAIL=true
LAUNCH_REQUIRE_BACKUP_RESTORE_TEST=true
